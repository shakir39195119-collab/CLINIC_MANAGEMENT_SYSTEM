NODE_ENV=production
PORT=8080
APP_URL=https://your-domain.example
JWT_SECRET=replace-this-with-a-long-random-secret
JWT_REFRESH_SECRET=replace-this-with-another-long-random-secret
DATA_FILE=./src/data/clinic-db.json

# Email, optional. App logs emails to console when SMTP is not configured.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="MediCore Clinic <no-reply@your-domain.example>"

# Payment keys, optional. Demo payments are recorded when these are absent.
STRIPE_SECRET_KEY=
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=

# Uploads, optional. Local uploads are used by default.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# SMS, optional. Wire your provider in src/services/sms.js.
SMS_PROVIDER_API_KEY=
